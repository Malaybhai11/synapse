{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://synapse.local/schemas/research_report.schema.json",
    "title": "ResearchReport",
    "version": "1.1.0",
    "description": "Primary research output representing a strict structured Synapse research report.",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier for the research report.",
            "pattern": "^[a-zA-Z0-9_-]{8,64}$"
        },
        "query": {
            "type": "string",
            "description": "The original user query or research topic.",
            "maxLength": 1000
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the report was generated."
        },
        "executive_summary": {
            "type": "string",
            "description": "A high-level summary of the research findings.",
            "maxLength": 5000
        },
        "technical_breakdown": {
            "type": "array",
            "description": "Detailed technical analysis broken down by topic.",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "topic": {
                        "type": "string",
                        "description": "The name or title of the technical topic."
                    },
                    "text": {
                        "type": "string",
                        "description": "Detailed explanation or analysis of the topic."
                    },
                    "evidence": {
                        "type": "string",
                        "description": "Supporting evidence or data for the technical breakdown."
                    }
                },
                "required": [
                    "topic",
                    "text",
                    "evidence"
                ],
                "additionalProperties": false
            }
        },
        "comparison_table": {
            "type": "object",
            "description": "A structured table for comparing entities, types, or solutions.",
            "properties": {
                "columns": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    },
                    "description": "The column headers for the comparison table."
                },
                "rows": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "description": "The rows of the comparison table. Each key maps to a header from the columns array."
                }
            },
            "required": [
                "columns",
                "rows"
            ],
            "additionalProperties": false
        },
        "pros": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            },
            "description": "List of advantages or positive aspects recorded."
        },
        "cons": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            },
            "description": "List of disadvantages or negative aspects recorded."
        },
        "confidence": {
            "type": "number",
            "description": "Overall confidence score for the report (0.00-1.00).",
            "minimum": 0,
            "maximum": 1
        },
        "sources": {
            "type": "array",
            "minItems": 1,
            "description": "List of source documents referenced in the report.",
            "items": {
                "type": "object",
                "properties": {
                    "doc_id": {
                        "type": "string",
                        "description": "Identifier of the source document."
                    },
                    "snippet": {
                        "type": "string",
                        "description": "Relevant text snippet from the source document.",
                        "maxLength": 2000
                    },
                    "uri": {
                        "type": "string",
                        "description": "URI or URL of the source document.",
                        "format": "uri"
                    },
                    "score": {
                        "type": "number",
                        "description": "Relevance score (0-1)."
                    }
                },
                "required": [
                    "doc_id",
                    "snippet",
                    "uri"
                ],
                "additionalProperties": false
            }
        },
        "claims": {
            "type": "array",
            "minItems": 1,
            "description": "List of claim objects extracted during research.",
            "items": {
                "$ref": "claim.schema.json"
            }
        },
        "metadata": {
            "type": "object",
            "description": "Execution metadata such as timing and token usage.",
            "properties": {
                "latency_ms": {
                    "type": "number",
                    "description": "Total generation time in milliseconds.",
                    "minimum": 0
                },
                "model": {
                    "type": "string",
                    "description": "Identifier of the LLM model used."
                },
                "tokens_used": {
                    "type": "integer",
                    "description": "Total token consumption.",
                    "minimum": 0
                },
                "version": {
                    "type": "string",
                    "enum": [
                        "1.1.0"
                    ],
                    "description": "The schema version of this report."
                }
            },
            "required": [
                "latency_ms",
                "model",
                "tokens_used",
                "version"
            ],
            "additionalProperties": false
        }
    },
    "required": [
        "id",
        "query",
        "timestamp",
        "executive_summary",
        "technical_breakdown",
        "comparison_table",
        "pros",
        "cons",
        "confidence",
        "sources",
        "claims",
        "metadata"
    ],
    "additionalProperties": false
}